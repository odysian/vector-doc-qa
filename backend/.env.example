# Environment
APP_ENV=development
APP_VERSION=unknown

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5434/document_intelligence

# API Keys
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# CORS
FRONTEND_URL=https://your-app.vercel.app
PORT=8000

# Application
SECRET_KEY=replace-with-32-plus-char-random-secret
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760
STORAGE_BACKEND=local
GCS_BUCKET_NAME=
GCP_PROJECT_ID=

# ARQ worker — seconds between idle Redis queue polls (higher = less Upstash traffic)
ARQ_POLL_DELAY_SECONDS=60

# Logging
LOG_LEVEL=INFO
ENABLE_FILE_LOGGING=true
LOG_FILE_MAX_BYTES=10485760
LOG_FILE_BACKUP_COUNT=5

project_id = "your-gcp-project-id"
region     = "us-east1"
zone       = "us-east1-b"

network        = "default"
subnetwork     = "default"
vm_name        = "quaero-backend"
machine_type   = "e2-micro"
static_ip_name = "quaero-backend-ip"

bucket_name          = "your-gcs-bucket-name"
ssh_user             = "your-ssh-user"
api_domain           = "api.example.com"
frontend_url         = "https://app.example.com"
backend_port         = 8000
enable_tls_bootstrap = true
certbot_email        = "you@example.com"
enable_ops_agent     = false
ops_agent_version    = "2.51.0"

ops_agent_collect_docker_logs = true
ops_agent_collect_host_metrics = true

ssh_public_keys = [
  "ssh-ed25519 AAAA... your-personal-key",
  "ssh-ed25519 AAAA... your-gha-deploy-key",
]

# Restrict SSH to admin CIDRs. Include IAP range for Console SSH backup.
ssh_source_ranges = ["203.0.113.10/32", "35.235.240.0/20"]

# Keep false except for temporary break-glass rollout.
allow_insecure_ssh_from_anywhere = false

# GitHub Actions self-hosted runner auto-registration.
# PAT requires: repository → Administration → Read and write (fine-grained)
# or classic PAT with repo scope.
# Leave empty to skip runner setup.
github_runner_pat     = ""
github_runner_version = "2.323.0"

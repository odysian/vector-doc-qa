{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ReviewRound",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "round",
    "summary",
    "patch_required",
    "repeat_signal",
    "findings",
    "deferred_followups"
  ],
  "properties": {
    "round": {
      "type": "integer",
      "minimum": 1,
      "maximum": 2
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "patch_required": {
      "type": "boolean"
    },
    "repeat_signal": {
      "type": "boolean"
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "severity",
          "title",
          "files",
          "disposition",
          "rationale",
          "patch_guidance"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "severity": {
            "type": "string",
            "enum": [
              "critical",
              "high",
              "medium",
              "low"
            ]
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "files": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "disposition": {
            "type": "string",
            "enum": [
              "patch_now",
              "defer",
              "dismiss"
            ]
          },
          "rationale": {
            "type": "string",
            "minLength": 1
          },
          "patch_guidance": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "deferred_followups": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "title",
          "reason"
        ],
        "properties": {
          "title": {
            "type": "string",
            "minLength": 1
          },
          "reason": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}

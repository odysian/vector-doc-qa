{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PatchRound",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "round",
    "applied",
    "commit_sha",
    "commit_message",
    "summary",
    "patched_finding_ids",
    "deferred_finding_ids"
  ],
  "properties": {
    "round": {
      "type": "integer",
      "minimum": 1,
      "maximum": 2
    },
    "applied": {
      "type": "boolean"
    },
    "commit_sha": {
      "type": "string"
    },
    "commit_message": {
      "type": "string"
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "patched_finding_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "deferred_finding_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
